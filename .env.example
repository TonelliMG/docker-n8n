# ===========================================================================
# Identificacao do projeto (prefixo dos containers e volumes)
# ===========================================================================
COMPOSE_PROJECT_NAME=n8n_stack

# ===========================================================================
# Acesso / rede
# ===========================================================================
# Porta que o n8n vai expor na sua maquina/servidor
N8N_PORT=5678

# Host e protocolo. Para uso local deixe localhost/http.
# Em servidor com dominio: N8N_HOST=n8n.seudominio.com e N8N_PROTOCOL=https
N8N_HOST=localhost
N8N_PROTOCOL=http

# URL publica usada para webhooks. Local: http://localhost:5678/
# Em servidor: https://n8n.seudominio.com/
WEBHOOK_URL=http://localhost:5678/

# Necessario para login funcionar em HTTP (localhost). Em HTTPS use true.
N8N_SECURE_COOKIE=false

# ===========================================================================
# Timezone
# ===========================================================================
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# ===========================================================================
# Banco de dados (PostgreSQL)
# ===========================================================================
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=changeme
N8N_DATABASE_SSL=false

# ===========================================================================
# Seguranca
# ===========================================================================
# Chave de criptografia das credenciais. GERE UMA UNICA E NUNCA MUDE depois.
# Gerar: openssl rand -hex 32   (ou)   docker run --rm alpine sh -c "head -c32 /dev/urandom | xxd -p -c64"
N8N_ENCRYPTION_KEY=changeme

# ===========================================================================
# Extras (silencia warnings e habilita execucao moderna)
# ===========================================================================
N8N_RUNNERS_ENABLED=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_DIAGNOSTICS_ENABLED=false
